{
  "_meta": {
    "description": "Seuils légaux de classification des entreprises françaises (TPE/PE/ME/ETI/GE) + critères CSRD wave + seuils CAC obligatoire. Sources : INSEE, Code de commerce art. L. 123-16, Directive CSRD. Utilisé par cfo-init pour classifier la société.",
    "version": "0.1.0",
    "last_updated": "2026-04-14",
    "sources": [
      "https://www.insee.fr/fr/metadonnees/definition/c1057",
      "https://www.legifrance.gouv.fr/codes/article_lc/LEGIARTI000038589878",
      "https://finance.ec.europa.eu/capital-markets-union-and-financial-markets/company-reporting-and-auditing/company-reporting/corporate-sustainability-reporting_en"
    ]
  },

  "tailles_entreprise_fr": {
    "_method": "Logique INSEE : critère effectif primaire, CA et bilan secondaires. Une entreprise est dans la catégorie supérieure dès qu'elle dépasse 2 critères sur 3.",
    "tpe_micro": {
      "label": "Très Petite Entreprise (TPE) / Microentreprise",
      "effectif_max": 9,
      "ca_max_eur": 2000000,
      "bilan_max_eur": 2000000,
      "regime_typique": ["micro", "reel_simplifie"],
      "obligation_cac": false
    },
    "pe": {
      "label": "Petite Entreprise (PE)",
      "effectif_max": 49,
      "ca_max_eur": 12000000,
      "bilan_max_eur": 6000000,
      "obligation_cac": false,
      "obligation_cac_si": "2/3 critères dépassés : effectif > 50, CA > 8M€, bilan > 4M€"
    },
    "me": {
      "label": "Moyenne Entreprise (ME)",
      "effectif_max": 249,
      "ca_max_eur": 50000000,
      "bilan_max_eur": 43000000,
      "obligation_cac": true,
      "obligation_cac_seuils": {
        "effectif_min": 50,
        "ca_min_eur": 8000000,
        "bilan_min_eur": 4000000
      }
    },
    "eti": {
      "label": "Entreprise de Taille Intermédiaire (ETI)",
      "effectif_max": 4999,
      "ca_max_eur": 1500000000,
      "bilan_max_eur": 2000000000,
      "obligation_cac": true
    },
    "ge": {
      "label": "Grande Entreprise (GE)",
      "effectif_min": 5000,
      "ca_min_eur": 1500000000,
      "obligation_cac": true,
      "csrd_wave_default": "wave_1"
    }
  },

  "csrd_waves": {
    "_method": "CSRD = Corporate Sustainability Reporting Directive. Application progressive par vagues. Wave 2 délai à 2028 (initialement 2026, repoussé en 2024 par directive Stop-the-Clock).",
    "wave_1": {
      "label": "Wave 1 - Grandes entités cotées et PIE",
      "first_reporting_year": 2024,
      "first_filing_year": 2025,
      "criteres": {
        "type": "Public Interest Entity (PIE) cotée OU grande entreprise déjà NFRD",
        "effectif_min": 500,
        "ca_min_eur": 50000000,
        "bilan_min_eur": 25000000,
        "logique": "PIE + au moins 2 des 3 critères ci-dessus"
      }
    },
    "wave_2": {
      "label": "Wave 2 - Grandes entités non cotées + mid-caps",
      "first_reporting_year": 2028,
      "first_filing_year": 2029,
      "delayed_by": "Directive (UE) 2025/794 du 14 avril 2025 - Stop-the-Clock",
      "criteres": {
        "effectif_min": 250,
        "ca_min_eur": 50000000,
        "bilan_min_eur": 25000000,
        "logique": "Au moins 2 des 3 critères ci-dessus"
      }
    },
    "wave_3": {
      "label": "Wave 3 - PME cotées",
      "first_reporting_year": 2028,
      "first_filing_year": 2029,
      "criteres": {
        "type": "PME cotée sur marché réglementé UE",
        "effectif_min": 10,
        "effectif_max": 250,
        "ca_min_eur": 900000,
        "bilan_min_eur": 450000
      }
    },
    "wave_4": {
      "label": "Wave 4 - Groupes hors UE avec activité significative en UE",
      "first_reporting_year": 2028,
      "first_filing_year": 2029,
      "criteres": {
        "ca_eu_min_eur": 150000000,
        "filiale_eu_required": true
      }
    },
    "hors_scope": {
      "label": "Hors scope CSRD",
      "criteres": "Entreprise non cotée < 250 salariés ET < 50M€ CA ET < 25M€ bilan",
      "veille_recommandee": true
    }
  },

  "regimes_fiscaux": {
    "is": {
      "label": "Impôt sur les Sociétés",
      "applicable_a": ["SAS", "SARL", "SA", "SCA", "SE"],
      "taux_normal": 25,
      "taux_reduit_pme": 15,
      "seuil_taux_reduit_eur": 42500,
      "condition_taux_reduit": "CA HT < 10M€ ET capital entièrement libéré ET détenu à 75% par personnes physiques"
    },
    "ir": {
      "label": "Impôt sur le Revenu",
      "applicable_a": ["EI", "EURL option IR", "SARL famille", "SAS option IR (5 ans)"],
      "categories": ["BIC", "BNC", "BA"]
    }
  },

  "regimes_tva": {
    "franchise_en_base": {
      "seuil_services_eur": 36800,
      "seuil_ventes_eur": 91900,
      "tolerance_services_eur": 39100,
      "tolerance_ventes_eur": 101000
    },
    "reel_simplifie": {
      "seuil_services_eur": 254000,
      "seuil_ventes_eur": 840000,
      "frequence_declaration": "annuelle (CA12)",
      "acomptes": "semestriels"
    },
    "reel_normal": {
      "frequence_declaration": "mensuelle (CA3) ou trimestrielle si TVA annuelle < 4000€"
    },
    "mini_reel": {
      "_comment": "Régime réel normal pour la TVA mais simplifié pour l'IS"
    }
  },

  "regimes_specifiques": {
    "domtom": {
      "label": "DOM-TOM (Martinique 972, Guadeloupe 971, Guyane 973, Réunion 974, Mayotte 976)",
      "abattement_is_pct": 33.33,
      "conditions_abattement": ["activité ≥ 5 ans", "75% CA dans le DOM"],
      "tva_taux_normal_pct": 8.5,
      "tva_taux_reduit_pct": 2.1,
      "regime_specifique": "TVA NPR (Non Perçue Récupérable)",
      "renvoi_ref": "paperasse/comptable - section DOM-TOM"
    },
    "alsace_moselle": {
      "label": "Alsace-Moselle (67/68/57)",
      "particularites": ["régime concordataire", "régime social local"]
    },
    "corse": {
      "label": "Corse (2A/2B)",
      "particularites": ["TVA taux 0,9% sur certaines opérations"]
    }
  }
}
