{
  "_meta": {
    "description": "Échéances fiscales et sociales France en offsets relatifs vs date de clôture (sauf échéances calendaires fixes). Utilisé par cfo-init/scripts/compute_calendar.py pour générer les dates absolues du calendrier de la société. Sources : impots.gouv.fr, urssaf.fr.",
    "version": "0.1.0",
    "last_updated": "2026-04-14",
    "convention_offsets": "+Nd = N jours après date de clôture, mensuel = chaque mois pendant 12 mois, calendar = date fixe annuelle"
  },

