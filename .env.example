# Configuration optionnelle — copier ce fichier en .env et remplir
# Le fichier .env est gitignored et ne quittera jamais votre machine.

# ─────────────────────────────────────────────────
# APIs externes — entièrement OPTIONNELLES
# Sans clé, le bundle utilise WebFetch (limites quota plus basses, données moins structurées)
# ─────────────────────────────────────────────────

# Pappers API (https://www.pappers.fr/api)
# Quota gratuit 1000 requêtes/mois, paid au-delà
PAPPERS_API_KEY=

# INSEE Sirene V3 (https://api.insee.fr/catalogue/)
# Gratuit, requiert création compte + clé OAuth
INSEE_CONSUMER_KEY=
INSEE_CONSUMER_SECRET=

# ─────────────────────────────────────────────────
# Tracking interne (local seulement, jamais transmis)
# ─────────────────────────────────────────────────

# Active le journal d'audit dans private/audit.log
AUDIT=false

# ─────────────────────────────────────────────────
# Connecteurs bancaires (skill cfo-tresorerie)
# Utilisez les MCP officiels plutôt que ces clés quand possible
# ─────────────────────────────────────────────────

# Bridge API (https://docs.bridgeapi.io/)
BRIDGE_CLIENT_ID=
BRIDGE_CLIENT_SECRET=
