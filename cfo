#!/usr/bin/env python3
"""
cfo, CLI unifiee pour moriarty-cfo.

Wrapper qui mappe une sous-commande courte a un script Python sous-jacent.
L'ensemble des arguments apres la sous-commande est forward vers le script
sans modification. Exit code et sorties preserves.

Usage :
  ./cfo <commande> [args...]
  ./cfo --help                     Liste les commandes par categorie
  ./cfo <commande> --help          Aide detaillee du script sous-jacent
  ./cfo --version                  Version du bundle (depuis pyproject.toml)

Exemples :
  ./cfo init-pme --siren 552120222 --denomination "ACME SAS" --fetch
  ./cfo calendar --closing-date 2026-12-31 --tva-regime reel_normal_mensuelle \
      --is-regime is --effectif 25 --output /tmp/cal.json
  ./cfo portfolio add --siren 552120222 --denomination "Client X" --taille pe
  ./cfo forecast-13w --solde-initial 150000 --encaissements-moyen 80000 \
      --decaissements-moyen 75000
  ./cfo bfr --creances-clients 200000 --dettes-fournisseurs 100000 \
      --ca-ttc 1200000 --achats-ttc 400000 --output /tmp/bfr.json
"""

