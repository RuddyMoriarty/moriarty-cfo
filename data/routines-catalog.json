    "conditions": {
      "always": "Bool - si true, routine universelle",
      "size_in": "Liste - TPE/PE/ME/ETI/GE",
      "secteur_naf_prefix": "Liste de préfixes NAF (ex: ['6201', '6202'])",
      "secteur_category": "Enum - saas | industrie | commerce | services_b2b | immo_lmnp | generaliste",
      "is_startup": "Bool",
      "has_investors": "Bool (equity funding raised)",
      "has_covenants": "Bool",
      "is_groupe": "Bool",
      "has_employees": "Bool (effectif > 0)",
      "csrd_wave_in": "Liste - wave_1 | wave_2 | wave_3 | hors_scope",
      "seuil_audit": "Bool (CA >= 1.55M€)",
      "has_stocks": "Bool (secteur avec inventaire)"
    },
    "skills_chain": "Liste ordonnée des skills à invoquer",
    "artefact": {
      "type": "html | pdf | xlsx | json | markdown",
      "template": "Chemin relatif vers template",
      "path_pattern": "Pattern avec placeholders {siren}, {yyyy}, {mm}, {qq}"
    },
    "notifications": {
      "before": "Liste d'offsets (J-15, J-7, J-1) pour rappels AVANT trigger",
      "level_min": "Niveau min (1-4) pour activer la notification"
    },
    "level_min": "Niveau min (1-4) pour que la routine soit programmée"
  },

