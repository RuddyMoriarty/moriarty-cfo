def flat_command_map() -> dict[str, str]:
    """Aplatit COMMANDS en {cmd_name: script_path}."""
    flat: dict[str, str] = {}
    for cmds in COMMANDS.values():
        for name, (path, _desc) in cmds.items():
            flat[name] = path
    return flat


def read_version() -> str:
    """Lit la version depuis pyproject.toml (sans tomllib pour supporter Python 3.9)."""
    pyproj = ROOT / "pyproject.toml"
    if not pyproj.exists():
        return "unknown"
    for line in pyproj.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if line.startswith("version"):
            # version = "0.2.4"
            return line.split("=", 1)[1].strip().strip('"').strip("'")
    return "unknown"


def print_help() -> None:
    version = read_version()
    print(f"cfo, moriarty-cfo CLI v{version}")
    print()
    print("Usage :")
    print("  ./cfo <commande> [args...]            Lance la commande")
    print("  ./cfo <commande> --help               Aide detaillee du script")
    print("  ./cfo --help                          Cette aide")
    print("  ./cfo --version                       Version du bundle")
    print("  ./cfo --list                          Liste plate (scripting)")
    print()
    print("Commandes par categorie :")
    for category, cmds in COMMANDS.items():
        print(f"\n  {category}")
        for name, (_path, desc) in sorted(cmds.items()):
            print(f"    {name:<28} {desc}")
    print()
    print("Docs : https://github.com/RuddyMoriarty/moriarty-cfo")


def print_list() -> None:
    """Format machine-readable : une commande par ligne."""
    for category, cmds in COMMANDS.items():
        for name in sorted(cmds.keys()):
            print(name)


def main(argv: list[str]) -> int:
    if len(argv) == 0 or argv[0] in {"-h", "--help", "help"}:
        print_help()
        return 0

    if argv[0] in {"-v", "--version", "version"}:
        print(f"moriarty-cfo v{read_version()}")
        return 0

    if argv[0] == "--list":
        print_list()
        return 0

    cmd = argv[0]
    flat = flat_command_map()
    if cmd not in flat:
        print(f"cfo: commande inconnue : {cmd}", file=sys.stderr)
        print("Lancer ./cfo --help pour voir les commandes disponibles.", file=sys.stderr)
        # Suggestions fuzzy (commencer par les prefixes communs)
        suggestions = [c for c in flat.keys() if cmd.split("-")[0] in c][:5]
        if suggestions:
            print(f"Vouliez-vous dire : {', '.join(suggestions)} ?", file=sys.stderr)
        return 2

    script_path = ROOT / flat[cmd]
    if not script_path.exists():
        print(f"cfo: script introuvable : {script_path}", file=sys.stderr)
        return 1

    # Forward tous les args suivants au script. On utilise execvp pour remplacer
    # le process courant (preserve exit code + signal propagation + tty).
    # Sur systemes sans execvp (Windows), fallback subprocess.
    args = [sys.executable, str(script_path)] + argv[1:]
    try:
        os.execvp(sys.executable, args)
    except OSError:
        # Fallback Windows ou systeme sans execvp : subprocess
        import subprocess
        proc = subprocess.run(args)
        return proc.returncode


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
