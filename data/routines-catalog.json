  "_schema": {
    "id": "Identifiant kebab-case unique",
    "name": "Nom lisible court",
    "description": "Une phrase qui décrit le cycle",
    "category": "universelle | taille | secteur | capital | dette | scope | cabinet",
    "frequency": "daily | weekly | monthly | quarterly | yearly | on_trigger",
    "trigger": {
      "type": "cron_day_of_month | cron_day_of_week | date_derived | date_fixed | condition_based",
      "day": "1-31 ou iso weekday 1-7",
      "hour": "0-23",
      "minute_pool": "Liste de minutes sûres hors :00 et :30",
      "offset_from_closing_days": "Entier signé (negatif = avant, positif = après)",
      "fire_at_absolute": "Date ISO si date_fixed"
